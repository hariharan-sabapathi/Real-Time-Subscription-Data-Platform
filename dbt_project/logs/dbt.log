[0m03:58:18.958402 [debug] [Thread-1 (]: On model.saas_lakehouse.intermediate_subscription_improved: /* {"app": "dbt", "dbt_version": "1.11.7", "profile_name": "saas_lakehouse", "target_name": "dev", "node_id": "model.saas_lakehouse.intermediate_subscription_improved"} */
create or replace view default.intermediate_subscription_improved
  
  
  as
    

WITH ranked_subscriptions AS (

    SELECT
        subscription_id,
        user_id,
        plan_id,
        status,
        operation,
        event_ts,
        event_time,

        ROW_NUMBER() OVER (
            PARTITION BY subscription_id
            ORDER BY event_ts DESC
        ) AS rn

    FROM default.staging_subscription

)

SELECT
    subscription_id,
    user_id,
    plan_id,
    status,
    event_time

FROM ranked_subscriptions
WHERE rn = 1

