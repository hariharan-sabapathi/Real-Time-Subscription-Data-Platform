WITH ranked_subscriptions AS (

    SELECT
        subscription_id,
        user_id,
        plan_id,
        status,
        operation,
        event_ts,
        event_time,

        ROW_NUMBER() OVER (
            PARTITION BY subscription_id
            ORDER BY event_ts DESC
        ) AS rn

    FROM default.staging_subscription

)

SELECT
    subscription_id,
    user_id,
    plan_id,
    status,
    event_time

FROM ranked_subscriptions
WHERE rn = 1
  
  limit 5

